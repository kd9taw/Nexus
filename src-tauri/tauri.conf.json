{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tempo",
  "version": "0.2.0",
  "identifier": "com.kd9taw.tempo",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Tempo",
        "label": "main",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "shortDescription": "Ham-aware chat-first HF transceiver",
    "longDescription": "Tempo is a ham-aware, chat-first HF digital transceiver UI built on the FT1 modem (libft1). It keeps the technical data a ham operator expects — SNR, audio offset, dT, dial freq/band/sideband, mode/tier, RV, T/R + slot timing — as first-class information in a clean, single-window design.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/hamlib/*"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "offlineInstaller"
      },
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
